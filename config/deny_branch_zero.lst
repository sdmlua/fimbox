# Files to delete from branches/0/ after the branch loop completes.
# Use # to keep a file. Use {} for the branch_id placeholder.
# DO NOT add branch_zero_complete.txt — it is the only durable proof that
# BranchZero ran successfully and must survive cleanup.
agree_binary_bufgrid.tif
agree_bufgrid.tif
agree_bufgrid_allo.tif
agree_bufgrid_dist.tif
agree_bufgrid_zerod.tif
agree_smogrid.tif
agree_smogrid_allo.tif
agree_smogrid_dist.tif
agree_smogrid_zerod.tif
backpool_stats.csv
bridge_elev_diff_meters_{}.tif
# fimbox names this bridge_elev_diff_{}.tif (no "_meters_"); same file role.
bridge_elev_diff_{}.tif
catch_list_{}.txt
coordFile_{}.txt
crosswalk_table_{}.csv
demDerived_reaches_{}.dbf
demDerived_reaches_{}.prj
demDerived_reaches_{}.shp
demDerived_reaches_{}.shx
# fimbox writes a single GPKG of demDerived_reaches; the upstream shell pipeline
# wrote shapefile parts which the four patterns above clean up. The split /
# filtered variants downstream are the actual hydroTable inputs, so this base
# file is safe to delete after CreateHAND completes.
demDerived_reaches_{}.gpkg
demDerived_reaches_split_{}.gpkg
demDerived_reaches_split_filtered_{}.gpkg
#demDerived_reaches_split_filtered_addedAttributes_crosswalked_{}.gpkg
demDerived_reaches_split_points_{}.gpkg
demDerived_streamPixels_{}.tif
# fimbox names the per-branch stream-pixel raster as demDerived_streamPixels_{bid}_ids*.tif
# (with the branch id BEFORE the "ids" suffix) — inundation-mapping put the id
# at the end. Catch both spellings so cleanup works regardless of provenance.
demDerived_streamPixels_ids_{}.tif
demDerived_streamPixels_ids_{}_allo.tif
demDerived_streamPixels_ids_{}_dist.tif
demDerived_streamPixels_{}_ids.tif
demDerived_streamPixels_{}_ids_allo.tif
demDerived_streamPixels_{}_ids_dist.tif
# fimbox writes dem_{bid}.tif as the per-branch working DEM (the levee-masked
# copy CreateHAND reads from). inundation-mapping called it dem_meters_{bid}.tif
# — catch both.
# dem_{}.tif                    — kept: clipped whole-AOI DEM
dem_burned_{}.tif
dem_burned_filled_{}.tif
dem_lateral_thalweg_adj_{}.tif
dem_meters_{}.tif
dem_thalwegCond_{}.tif
flowaccum_d8_burned_filled_{}.tif
# flowdir_d8_burned_filled_{}.tif  — kept: whole-AOI D8 flow direction, shared input for all non-zero branches
flowdir_d8_burned_filled_flows_{}.tif
flows_grid_boolean_{}.tif
flows_points_pixels_{}.gpkg
gw_catchments_pixels_{}.tif
